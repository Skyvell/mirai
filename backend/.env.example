# Local development configuration. Copy to `.env` and fill in.
# Cloud Run injects these in deployed environments (see infra/opentofu/modules/app).

# Clerk — JWT verification uses only the public JWKS, no secret key.
# Both values come from the Clerk instance's Frontend API URL:
#   CLERK_ISSUER    = https://<slug>.clerk.accounts.dev
#   CLERK_JWKS_URL  = <issuer>/.well-known/jwks.json
CLERK_JWKS_URL=https://<slug>.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://<slug>.clerk.accounts.dev

# CORS — the frontend origin allowed to call the API.
FRONTEND_ORIGIN=http://localhost:5173
